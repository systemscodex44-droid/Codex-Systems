<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Codex Hub — Central de Vendas & Operação</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@500;600;700;800&family=Barlow:wght@400;500;600&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{
  --bg:#F5F6FB; --surface:#FFFFFF; --card:#FFFFFF; --card-hover:#F0F3FF;
  --border:#E1E4F2; --border-soft:#ECEEF8;
  --accent:#4A7FFF; --accent-text:#3458D6; --accent-2:#7B5EFF;
  --grad:linear-gradient(135deg,#4A7FFF 0%,#7B5EFF 100%);
  --text:#15162B; --text-2:#5B5C7A; --text-3:#83839E;
  --success:#15803D; --success-bg:#E7F6ED; --success-border:#BCE6CB;
  --warning:#B45309; --warning-bg:#FFF3E0; --warning-border:#F3D9AE;
  --danger:#DC2626; --danger-bg:#FDECEC; --danger-border:#F6C6C6;
  --info-bg:#EAF1FF; --info-border:#C9DAFF;
  --sidebar-w:248px;
}
html{scroll-behavior:smooth}
body{font-family:'Barlow',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;font-size:14px;line-height:1.6}
.condensed{font-family:'Barlow Condensed',sans-serif}

.app{display:flex;min-height:100vh}

.sidebar{width:var(--sidebar-w);background:var(--surface);border-right:1px solid var(--border);position:fixed;top:0;left:0;bottom:0;display:flex;flex-direction:column;z-index:200;transition:transform .25s ease}
.sb-brand{padding:22px 20px 18px;border-bottom:1px solid var(--border-soft);display:flex;align-items:center;gap:10px}
.sb-logo-text{font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:19px;letter-spacing:.04em;color:var(--text)}
.sb-badge{font-size:9px;font-weight:700;letter-spacing:.1em;background:var(--info-bg);color:var(--accent-text);padding:2px 7px;border-radius:4px;border:1px solid var(--info-border)}
.sb-nav{padding:14px 0;flex:1;overflow-y:auto}
.sb-group-title{font-size:9px;font-weight:700;letter-spacing:.16em;text-transform:uppercase;color:var(--text-3);padding:16px 20px 7px}
.sb-link{display:flex;align-items:center;gap:10px;padding:9px 20px;color:var(--text-2);text-decoration:none;font-size:13px;font-weight:500;border-left:2px solid transparent;cursor:pointer;transition:all .15s}
.sb-link:hover{color:var(--text);background:var(--card-hover)}
.sb-link.active{color:var(--text);border-left-color:var(--accent);background:var(--info-bg);font-weight:600}
.sb-icon{width:16px;text-align:center;flex-shrink:0;opacity:.85}
.sb-footer{padding:14px 20px;border-top:1px solid var(--border-soft);font-size:10.5px;color:var(--text-3);line-height:1.6}

.main{margin-left:var(--sidebar-w);flex:1;min-height:100vh;display:flex;flex-direction:column}
.topbar{position:sticky;top:0;z-index:100;background:rgba(245,246,251,.88);backdrop-filter:blur(10px);border-bottom:1px solid var(--border);padding:14px 36px}
.search-wrap{position:relative;max-width:640px}
.search-input{width:100%;background:var(--surface);border:1.5px solid var(--border);border-radius:9px;padding:11px 16px 11px 40px;font-family:'Barlow',sans-serif;font-size:14px;color:var(--text);outline:none;transition:border-color .15s}
.search-input:focus{border-color:var(--accent)}
.search-input::placeholder{color:var(--text-3)}
.search-icon{position:absolute;left:14px;top:50%;transform:translateY(-50%);color:var(--text-3);font-size:14px}
.search-kbd{position:absolute;right:12px;top:50%;transform:translateY(-50%);font-size:10px;color:var(--text-3);background:var(--bg);border:1px solid var(--border);border-radius:4px;padding:2px 6px}
.search-results{position:absolute;top:calc(100% + 8px);left:0;right:0;background:var(--card);border:1px solid var(--border);border-radius:10px;max-height:420px;overflow-y:auto;box-shadow:0 16px 40px rgba(20,24,60,.12);display:none;z-index:300}
.search-results.show{display:block}
.sr-item{padding:12px 16px;border-bottom:1px solid var(--border-soft);cursor:pointer;transition:background .12s}
.sr-item:last-child{border-bottom:none}
.sr-item:hover,.sr-item.sel{background:var(--card-hover)}
.sr-cat{font-size:9px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--accent-text);margin-bottom:3px}
.sr-title{font-size:13.5px;font-weight:500;color:var(--text);margin-bottom:2px}
.sr-snippet{font-size:12px;color:var(--text-2);line-height:1.5;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
.sr-empty{padding:24px 16px;text-align:center;color:var(--text-3);font-size:13px}

.content{flex:1;padding:36px;max-width:1180px}
.view{display:none;animation:fadeIn .25s ease}
.view.active{display:block}
@keyframes fadeIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}

.page-eyebrow{font-size:10px;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:var(--accent-text);margin-bottom:8px}
.page-title{font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:32px;letter-spacing:.01em;text-transform:uppercase;color:var(--text);margin-bottom:8px;line-height:1.1}
.page-sub{font-size:14.5px;color:var(--text-2);max-width:640px;line-height:1.65;margin-bottom:28px}
h3.block-title{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:18px;letter-spacing:.02em;text-transform:uppercase;color:var(--text);margin:30px 0 14px}
h3.block-title:first-child{margin-top:0}

.card{background:var(--card);border:1px solid var(--border);border-radius:11px;padding:20px;margin-bottom:12px;box-shadow:0 1px 2px rgba(20,24,60,.03)}

.hero-search-block{text-align:center;padding:50px 20px 36px;margin-bottom:8px}
.hero-eyebrow{font-size:11px;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:var(--accent-text);margin-bottom:14px}
.hero-title{font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:38px;letter-spacing:.01em;color:var(--text);line-height:1.15;margin-bottom:10px}
.hero-sub{font-size:15px;color:var(--text-2);max-width:480px;margin:0 auto 26px;line-height:1.6}
.hero-search{max-width:560px;margin:0 auto;position:relative}
.chips{display:flex;gap:8px;justify-content:center;flex-wrap:wrap;margin-top:16px}
.chip{font-size:12px;color:var(--text-2);background:var(--card);border:1px solid var(--border);border-radius:18px;padding:6px 14px;cursor:pointer;transition:all .15s}
.chip:hover{border-color:var(--accent);color:var(--accent-text)}

.quick-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:8px}
.quick-card{background:var(--card);border:1px solid var(--border);border-radius:11px;padding:18px;cursor:pointer;transition:all .15s;box-shadow:0 1px 2px rgba(20,24,60,.03)}
.quick-card:hover{border-color:var(--accent);background:var(--card-hover);transform:translateY(-1px)}
.quick-icon{font-size:20px;margin-bottom:10px;display:block}
.quick-label{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:14px;letter-spacing:.02em;text-transform:uppercase;color:var(--text);margin-bottom:3px}
.quick-desc{font-size:11.5px;color:var(--text-2);line-height:1.5}

.rhythm-card{display:flex;gap:14px;align-items:flex-start}
.rhythm-day{min-width:90px}
.rhythm-day-name{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:13px;text-transform:uppercase;color:var(--accent-text)}
.rhythm-day-time{font-size:11px;color:var(--text-3)}
.rhythm-text{font-size:13px;color:var(--text-2);line-height:1.6}

.belief-banner{background:linear-gradient(135deg,rgba(74,127,255,.07),rgba(123,94,255,.05));border:1px solid var(--info-border);border-radius:12px;padding:22px 26px;margin-bottom:24px}
.belief-label{font-size:10px;font-weight:700;letter-spacing:.16em;text-transform:uppercase;color:var(--accent-text);margin-bottom:8px}
.belief-text{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:21px;color:var(--text);line-height:1.4}

.filter-row{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:20px}
.filter-pill{font-size:12px;font-weight:500;padding:6px 14px;border-radius:16px;background:var(--card);border:1px solid var(--border);color:var(--text-2);cursor:pointer;transition:all .15s}
.filter-pill:hover{border-color:var(--accent);color:var(--accent-text)}
.filter-pill.active{background:var(--accent);border-color:var(--accent);color:#fff}

.script-card{background:var(--card);border:1px solid var(--border);border-radius:11px;padding:18px 20px;margin-bottom:10px;box-shadow:0 1px 2px rgba(20,24,60,.03)}
.script-head{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:10px;gap:12px}
.script-cat{font-size:9.5px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--accent-text);margin-bottom:4px}
.script-title{font-size:15px;font-weight:600;color:var(--text)}
.script-trigger{font-size:12px;color:var(--text-3);margin-top:3px;font-style:italic}
.script-body{background:var(--info-bg);border-left:2.5px solid var(--accent);border-radius:6px;padding:13px 16px;font-size:13.5px;color:#1E2347;line-height:1.7;white-space:pre-wrap;margin-top:4px}
.btn-copy{flex-shrink:0;display:flex;align-items:center;gap:6px;background:var(--card);border:1px solid var(--border);color:var(--text-2);font-size:12px;font-weight:500;padding:7px 13px;border-radius:7px;cursor:pointer;transition:all .15s;white-space:nowrap}
.btn-copy:hover{border-color:var(--accent);color:var(--accent-text)}
.btn-copy.copied{background:var(--success-bg);border-color:var(--success-border);color:var(--success)}
.btn-fav{background:none;border:none;color:var(--text-3);font-size:16px;cursor:pointer;padding:4px;transition:color .15s;flex-shrink:0}
.btn-fav.active{color:var(--warning)}

.flow-step{display:flex;gap:0;margin-bottom:0;cursor:pointer}
.flow-num-col{display:flex;flex-direction:column;align-items:center;width:48px;flex-shrink:0}
.flow-num{width:34px;height:34px;border-radius:8px;background:var(--info-bg);border:1px solid var(--info-border);display:flex;align-items:center;justify-content:center;font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:14px;color:var(--accent-text);flex-shrink:0;z-index:2}
.flow-num.gate{background:var(--warning-bg);border-color:var(--warning-border);color:var(--warning)}
.flow-num.loop{background:var(--success-bg);border-color:var(--success-border);color:var(--success)}
.flow-line{width:2px;flex:1;background:var(--border);margin:2px 0}
.flow-step:last-child .flow-line{display:none}
.flow-content{flex:1;padding-bottom:22px}
.flow-card{background:var(--card);border:1px solid var(--border);border-radius:10px;padding:16px 18px;margin-left:14px;margin-top:-2px;transition:border-color .15s;box-shadow:0 1px 2px rgba(20,24,60,.03)}
.flow-card:hover{border-color:#B9C6F5}
.flow-card.gate-card{border-color:var(--warning-border)}
.flow-title-row{display:flex;justify-content:space-between;align-items:center;cursor:pointer}
.flow-title{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:16px;letter-spacing:.02em;text-transform:uppercase;color:var(--text)}
.flow-gate-tag{font-size:9px;font-weight:700;letter-spacing:.08em;background:var(--warning-bg);color:var(--warning);padding:2px 8px;border-radius:4px;margin-left:8px}
.flow-chevron{color:var(--text-3);font-size:12px;transition:transform .2s}
.flow-card.open .flow-chevron{transform:rotate(180deg)}
.flow-detail{display:none;margin-top:14px;padding-top:14px;border-top:1px solid var(--border-soft)}
.flow-card.open .flow-detail{display:block}
.flow-detail-row{margin-bottom:10px}
.flow-detail-label{font-size:9.5px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--text-3);margin-bottom:3px}
.flow-detail-text{font-size:13px;color:var(--text-2);line-height:1.6}
.flow-related-btn{font-size:12px;color:var(--accent-text);cursor:pointer;display:inline-flex;align-items:center;gap:5px;margin-top:6px;font-weight:500}
.flow-related-btn:hover{text-decoration:underline}

.flow-img-banner{display:flex;align-items:center;gap:14px;background:var(--card);border:1px solid var(--info-border);border-radius:11px;padding:14px 18px;margin-bottom:24px;cursor:pointer;transition:all .15s}
.flow-img-banner:hover{background:var(--card-hover);border-color:var(--accent)}
.flow-img-banner-icon{font-size:22px}
.flow-img-banner-title{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:14px;text-transform:uppercase;color:var(--text)}
.flow-img-banner-desc{font-size:12px;color:var(--text-2)}
.flow-img-banner-arrow{margin-left:auto;color:var(--accent-text);font-size:16px}

.flowimg-card{background:var(--card);border:1px solid var(--border);border-radius:12px;overflow:hidden;margin-bottom:16px;box-shadow:0 1px 3px rgba(20,24,60,.05);padding:20px}
.diagram-wrap{width:100%;overflow-x:auto;padding-bottom:6px}
.diagram-wrap svg{display:block;min-width:760px}
.diagram-legend{display:flex;gap:18px;flex-wrap:wrap;margin-top:16px;padding-top:14px;border-top:1px solid var(--border-soft)}
.legend-item{display:flex;align-items:center;gap:6px;font-size:12px;color:var(--text-2)}
.legend-dot{width:10px;height:10px;border-radius:3px;display:inline-block}
.legend-dot.diamond-dot{border-radius:0;transform:rotate(45deg);width:8px;height:8px}
.dg-node{cursor:pointer}
.dg-node:hover rect{stroke:var(--accent);stroke-width:2.5}
.dg-node.selected rect{stroke:var(--accent);stroke-width:3}
.dg-node.selected.gate rect{stroke:var(--warning)}
.dg-node.selected.loop rect{stroke:var(--success)}
.dg-decision{cursor:pointer}
.dg-decision:hover polygon{stroke:var(--accent-2);stroke-width:2.5}
.dg-decision.selected polygon{stroke:var(--accent-2);stroke-width:3}
.detail-chip{display:inline-flex;align-items:center;gap:5px;font-size:12px;font-weight:500;color:var(--accent-text);background:var(--info-bg);border:1px solid var(--info-border);border-radius:14px;padding:5px 12px;cursor:pointer;margin-right:6px;margin-top:6px;transition:all .15s}
.detail-chip:hover{background:var(--accent);color:#fff;border-color:var(--accent)}
.detail-title{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:17px;text-transform:uppercase;color:var(--text);margin-bottom:10px}

.profile-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.profile-card{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:20px;position:relative;box-shadow:0 1px 2px rgba(20,24,60,.03)}
.profile-card.priority{border-color:var(--info-border)}
.profile-priority-tag{position:absolute;top:16px;right:16px;font-size:9px;font-weight:700;letter-spacing:.08em;background:var(--info-bg);color:var(--accent-text);padding:3px 9px;border-radius:10px}
.profile-name{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:19px;text-transform:uppercase;letter-spacing:.01em;color:var(--text);margin-bottom:8px}
.profile-who{font-size:13px;color:var(--text-2);line-height:1.6;margin-bottom:14px}
.profile-field{margin-bottom:10px}
.profile-field-label{font-size:9.5px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--text-3);margin-bottom:3px}
.profile-field-text{font-size:12.5px;color:var(--text-2);line-height:1.55}
.profile-phrase{background:var(--info-bg);border-left:2.5px solid var(--accent);border-radius:6px;padding:10px 13px;font-size:13px;color:#1E2347;font-style:italic;margin-top:4px}

table.price-table{width:100%;border-collapse:collapse;background:var(--card);border-radius:10px;overflow:hidden;border:1px solid var(--border)}
table.price-table th{background:var(--bg);font-size:11px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--text-2);padding:12px 14px;text-align:left;border-bottom:1px solid var(--border)}
table.price-table td{padding:13px 14px;font-size:13.5px;color:var(--text-2);border-bottom:1px solid var(--border-soft)}
table.price-table tr:last-child td{border-bottom:none}
table.price-table td.strong{color:var(--text);font-weight:600}
table.price-table td.bundle{color:var(--accent-text);font-weight:600;background:var(--info-bg)}
.bundle-compare{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-top:16px}
.bundle-box{background:var(--card);border:1px solid var(--border);border-radius:11px;padding:18px;box-shadow:0 1px 2px rgba(20,24,60,.03)}
.bundle-box.rec{border-color:var(--info-border);background:linear-gradient(135deg,rgba(74,127,255,.05),rgba(123,94,255,.03))}
.bundle-box-title{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:15px;text-transform:uppercase;color:var(--text);margin-bottom:4px}
.bundle-price{font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:24px;color:var(--accent-text);margin-bottom:10px}
.bundle-item{font-size:12.5px;color:var(--text-2);margin-bottom:6px;padding-left:16px;position:relative}
.bundle-item::before{content:'✓';position:absolute;left:0;color:var(--success)}

.gate-card-full{background:var(--card);border:1px solid var(--border);border-radius:12px;overflow:hidden;margin-bottom:14px;box-shadow:0 1px 2px rgba(20,24,60,.03)}
.gate-bar{height:4px}
.gate-bar.g1{background:var(--accent)}
.gate-bar.g2{background:var(--warning)}
.gate-bar.g3{background:var(--accent-2)}
.gate-body{padding:20px 22px}
.gate-head{display:flex;align-items:center;gap:14px;margin-bottom:14px}
.gate-num{width:44px;height:44px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:19px;flex-shrink:0}
.gate-num.g1{background:var(--info-bg);color:var(--accent-text)}
.gate-num.g2{background:var(--warning-bg);color:var(--warning)}
.gate-num.g3{background:rgba(123,94,255,.1);color:var(--accent-2)}
.gate-title{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:17px;text-transform:uppercase;color:var(--text)}
.gate-sub{font-size:12px;color:var(--text-3)}
.gate-q-box{background:var(--info-bg);border-radius:8px;padding:12px 16px;margin-bottom:12px;font-size:13.5px;font-style:italic;color:#1E2347}
.gate-rule{background:var(--danger-bg);border:1px solid var(--danger-border);border-radius:8px;padding:11px 15px;font-size:12.5px;color:#7A1F1F;margin-top:10px}
.gate-rule strong{color:var(--danger);display:block;font-size:11px;letter-spacing:.05em;margin-bottom:3px;text-transform:uppercase}
.gate-protect{display:inline-block;margin-top:12px;font-size:12px;font-weight:600;background:var(--info-bg);color:var(--accent-text);padding:5px 13px;border-radius:14px}

.voice-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:24px}
.voice-card{border-top:2px solid var(--accent);padding-top:12px}
.voice-name{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:15px;text-transform:uppercase;color:var(--text);margin-bottom:6px}
.voice-desc{font-size:12px;color:var(--text-2);line-height:1.55}
.slogan-box{font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:24px;text-transform:uppercase;color:var(--text);background:var(--card);border:1px solid var(--info-border);border-radius:10px;padding:20px 24px;margin-bottom:8px;line-height:1.3}

.tool-card{display:flex;align-items:center;gap:16px;background:var(--card);border:1px solid var(--border);border-radius:11px;padding:18px 20px;margin-bottom:10px;text-decoration:none;color:inherit;transition:all .15s;box-shadow:0 1px 2px rgba(20,24,60,.03)}
.tool-card:hover{border-color:var(--accent);background:var(--card-hover)}
.tool-icon{width:44px;height:44px;border-radius:10px;background:var(--info-bg);display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0}
.tool-title{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:15px;text-transform:uppercase;color:var(--text);margin-bottom:2px}
.tool-desc{font-size:12.5px;color:var(--text-2)}
.tool-arrow{margin-left:auto;color:var(--text-3);font-size:18px}
.mini-list{font-size:13px;color:var(--text-2);line-height:1.8;padding-left:4px}
.mini-list b{color:var(--text)}

.toast{position:fixed;bottom:24px;right:24px;background:var(--success-bg);border:1px solid var(--success-border);color:var(--success);padding:11px 18px;border-radius:9px;font-size:13px;font-weight:600;opacity:0;transform:translateY(10px);transition:all .25s;z-index:1000;display:flex;align-items:center;gap:8px;box-shadow:0 10px 30px rgba(20,40,30,.15)}
.toast.show{opacity:1;transform:translateY(0)}

.mobile-toggle{display:none;background:var(--card);border:1px solid var(--border);color:var(--text);width:38px;height:38px;border-radius:8px;align-items:center;justify-content:center;font-size:16px;cursor:pointer}
@media(max-width:900px){
  .sidebar{transform:translateX(-100%)}
  .sidebar.open{transform:translateX(0)}
  .main{margin-left:0}
  .mobile-toggle{display:flex}
