const SEARCH_INDEX = [];
function buildSearchIndex(){
  SCRIPTS.forEach(function(s){
    SEARCH_INDEX.push({
      cat:'Script · '+s.cat, title:s.title, snippet:s.text, view:'scripts',
      go:function(){
        navigate('scripts'); activeFilter='Todos'; renderScripts();
        setTimeout(function(){
          const el=document.getElementById('script-'+s.id);
          if(el){ el.scrollIntoView({behavior:'smooth',block:'center'}); el.style.borderColor='var(--accent)'; setTimeout(function(){el.style.borderColor='';},2000);}
        },80);
      },
      kw:(s.title+' '+s.trigger+' '+s.text+' '+s.cat).toLowerCase()
    });
  });
  GATES.forEach(function(g){
    SEARCH_INDEX.push({cat:'Portão de Decisão', title:g.title, snippet:g.question, view:'portoes', go:function(){navigate('portoes');}, kw:(g.title+' '+g.question+' '+g.rule).toLowerCase()});
  });
  PROFILES.forEach(function(p){
    SEARCH_INDEX.push({cat:'Perfil de Cliente', title:p.name, snippet:p.frase, view:'perfis', go:function(){navigate('perfis');}, kw:(p.name+' '+p.who+' '+p.dor+' '+p.frase).toLowerCase()});
  });
  STAGES.forEach(function(st){
    SEARCH_INDEX.push({cat:'Etapa do Fluxo', title:st.title, snippet:st.objective, view:'fluxo', go:function(){navigate('fluxo');}, kw:(st.title+' '+st.objective+' '+st.output).toLowerCase()});
  });
  SEARCH_INDEX.push({cat:'Ferramenta', title:'Formulário de Kick-off', snippet:'Abrir o formulário interativo para enviar ao cliente', view:'ferramentas', go:function(){navigate('ferramentas');}, kw:'kickoff kick-off formulario formulário enviar cliente'});
  SEARCH_INDEX.push({cat:'Fluxograma', title:'Fluxograma Visual', snippet:'Imagens completas das 7 etapas e dos 3 portões de decisão', view:'fluxoimg', go:function(){navigate('fluxoimg');}, kw:'fluxograma visual imagem desenhado fluxo'});
  SEARCH_INDEX.push({cat:'Preços', title:'Tabela de preços e bundles', snippet:'Landing Page, Site Institucional, Dashboard, Sistema', view:'precos', go:function(){navigate('precos');}, kw:'preço preco tabela bundle valor investimento orçamento'});
}

const searchInput = document.getElementById('globalSearch');
const searchResults = document.getElementById('searchResults');
let selIndex = -1;

function runSearch(q){
  q = q.trim().toLowerCase();
  if(!q){ searchResults.classList.remove('show'); return; }
  const results = SEARCH_INDEX.filter(function(item){return item.kw.indexOf(q)!==-1;}).slice(0,8);
  selIndex = -1;
  if(!results.length){
    searchResults.innerHTML = '<div class="sr-empty">Nada encontrado para "'+q+'"</div>';
  } else {
    searchResults.innerHTML = results.map(function(r,i){
      return '<div class="sr-item" data-idx="'+i+'">'+
        '<div class="sr-cat">'+r.cat+'</div>'+
        '<div class="sr-title">'+r.title+'</div>'+
        '<div class="sr-snippet">'+r.snippet+'</div>'+
      '</div>';
    }).join('');
    searchResults._results = results;
    searchResults.querySelectorAll('.sr-item').forEach(function(el){
      el.onclick = function(){ results[el.dataset.idx].go(); closeSearch(); };
    });
  }
  searchResults.classList.add('show');
}
function closeSearch(){ searchResults.classList.remove('show'); searchInput.value=''; }

searchInput.addEventListener('input', function(e){runSearch(e.target.value);});
searchInput.addEventListener('keydown', function(e){
  const items = searchResults.querySelectorAll('.sr-item');
  if(e.key==='ArrowDown'){ e.preventDefault(); selIndex=Math.min(selIndex+1,items.length-1); updateSel(items); }
  if(e.key==='ArrowUp'){ e.preventDefault(); selIndex=Math.max(selIndex-1,0); updateSel(items); }
  if(e.key==='Enter'){ if(selIndex>=0 && searchResults._results){ searchResults._results[selIndex].go(); closeSearch(); } }
  if(e.key==='Escape'){ closeSearch(); }
});
function updateSel(items){
  items.forEach(function(it,i){it.classList.toggle('sel', i===selIndex);});
  if(items[selIndex]) items[selIndex].scrollIntoView({block:'nearest'});
}

document.addEventListener('click', function(e){
  if(!e.target.closest('.search-wrap')) searchResults.classList.remove('show');
});
document.addEventListener('keydown', function(e){
  if(e.key==='/' && document.activeElement!==searchInput){ e.preventDefault(); searchInput.focus(); }
});

document.querySelectorAll('.chip').forEach(function(chip){
  chip.onclick = function(){ searchInput.value = chip.dataset.q; searchInput.focus(); runSearch(chip.dataset.q); };
});

function navigate(view){
  document.querySelectorAll('.view').forEach(function(v){v.classList.remove('active');});
  document.getElementById('view-'+view).classList.add('active');
  document.querySelectorAll('.sb-link').forEach(function(l){l.classList.toggle('active', l.dataset.view===view);});
  window.scrollTo(0,0);
  document.getElementById('sidebar').classList.remove('open');
  document.getElementById('overlay').classList.remove('show');
  location.hash = view;
}
document.querySelectorAll('[data-view]').forEach(function(el){
  el.addEventListener('click', function(){navigate(el.dataset.view);});
});

document.getElementById('mobileToggle').onclick = function(){
  document.getElementById('sidebar').classList.toggle('open');
  document.getElementById('overlay').classList.toggle('show');
};
document.getElementById('overlay').onclick = function(){
  document.getElementById('sidebar').classList.remove('open');
  document.getElementById('overlay').classList.remove('show');
};

renderScripts();
renderFlow();
renderDiagram();
renderGates();
renderProfiles();
renderPrices();
renderFavoritesHome();
buildSearchIndex();

const initialView = location.hash ? location.hash.replace('#','') : 'home';
if(document.getElementById('view-'+initialView)) navigate(initialView);
</script>
