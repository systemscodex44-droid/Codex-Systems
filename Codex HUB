function buildDiagramSVG(){
  const W=248,H=92,GAP=22,SP=W+GAP;
  const row1y=30, row2y=320, diaY=150;
  const xs=[20,20+SP,20+SP*2,20+SP*3];
  const dCx = xs[3]+W/2, dCy = diaY+45;

  let svg = '<svg viewBox="0 0 1140 460" xmlns="http://www.w3.org/2000/svg">';
  svg += '<defs>'+
    '<marker id="aB" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="8" markerHeight="8" orient="auto-start-reverse"><path d="M0,0L10,5L0,10Z" fill="#4A7FFF"/></marker>'+
    '<marker id="aP" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="8" markerHeight="8" orient="auto-start-reverse"><path d="M0,0L10,5L0,10Z" fill="#7B5EFF"/></marker>'+
    '<marker id="aG" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="8" markerHeight="8" orient="auto-start-reverse"><path d="M0,0L10,5L0,10Z" fill="#22C55E"/></marker>'+
    '<marker id="aO" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="8" markerHeight="8" orient="auto-start-reverse"><path d="M0,0L10,5L0,10Z" fill="#F59E0B"/></marker>'+
  '</defs>';

  // row 1 nodes
  for(let i=0;i<4;i++){ svg += diagramNodeHTML(STAGES[i], i, xs[i], row1y, W, H); }
  // row 1 arrows
  for(let i=0;i<3;i++){
    const x1 = xs[i]+W, x2 = xs[i+1];
    svg += '<line x1="'+x1+'" y1="'+(row1y+H/2)+'" x2="'+(x2-3)+'" y2="'+(row1y+H/2)+'" stroke="#4A7FFF" stroke-width="2.2" marker-end="url(#aB)"/>';
  }
  // vertical arrow box4 -> diamond
  svg += '<line x1="'+dCx+'" y1="'+(row1y+H)+'" x2="'+dCx+'" y2="'+(diaY-3)+'" stroke="#7B5EFF" stroke-width="2.2" marker-end="url(#aP)"/>';

  // decision diamond
  svg += '<g class="dg-decision" data-decision="1">'+
    '<polygon points="'+dCx+',98 '+(dCx+78)+',150 '+dCx+',202 '+(dCx-78)+',150" fill="#F5F2FF" stroke="#D9CCFF" stroke-width="1.5" transform="translate(0,'+(diaY-100)+')"/>'+
    '<text x="'+dCx+'" y="'+(diaY+42)+'" text-anchor="middle" font-family="Barlow Condensed, Arial" font-weight="700" font-size="12.5" fill="#4A3A8A">CLIENTE</text>'+
    '<text x="'+dCx+'" y="'+(diaY+58)+'" text-anchor="middle" font-family="Barlow Condensed, Arial" font-weight="700" font-size="12.5" fill="#4A3A8A">APROVOU?</text>'+
  '</g>';

  const diaBottom = diaY+100, diaRight = dCx+78, diaLeftY = diaY+50;

  // "Não" branch down to box5 (xs[3] in row2)
  svg += '<line x1="'+dCx+'" y1="'+diaBottom+'" x2="'+dCx+'" y2="'+(row2y-3)+'" stroke="#7B5EFF" stroke-width="2.2" marker-end="url(#aP)"/>';
  svg += '<rect x="'+(dCx+8)+'" y="'+(diaBottom+10)+'" width="54" height="20" rx="10" fill="#F5F2FF"/>';
  svg += '<text x="'+(dCx+35)+'" y="'+(diaBottom+24)+'" text-anchor="middle" font-family="Arial" font-weight="700" font-size="10" fill="#6B4FC0">NÃO →</text>';

  // "Sim" bypass elbow to box6 (xs[2] in row2)
  const sx = dCx + 78, ex = xs[2]+W/2;
  const elbowX = sx+45, elbowMidY = row2y+H/2;
  svg += '<path d="M'+sx+','+diaLeftY+' L'+elbowX+','+diaLeftY+' L'+elbowX+','+elbowMidY+' L'+(ex)+','+elbowMidY+' L'+ex+','+(row2y-3)+'" fill="none" stroke="#22C55E" stroke-width="2" stroke-dasharray="6,5" marker-end="url(#aG)"/>';
  svg += '<rect x="'+(sx+10)+'" y="'+(diaLeftY-36)+'" width="66" height="20" rx="10" fill="#E7F6ED"/>';
  svg += '<text x="'+(sx+43)+'" y="'+(diaLeftY-22)+'" text-anchor="middle" font-family="Arial" font-weight="700" font-size="9.5" fill="#15803D">SIM →</text>';

  // row 2 nodes (5,6,7 under cols 4,3,2)
  svg += diagramNodeHTML(STAGES[4], 4, xs[3], row2y, W, H);
  svg += diagramNodeHTML(STAGES[5], 5, xs[2], row2y, W, H);
  svg += diagramNodeHTML(STAGES[6], 6, xs[1], row2y, W, H);

  // row2 arrows leftward
  svg += '<line x1="'+xs[3]+'" y1="'+(row2y+H/2)+'" x2="'+(xs[2]+W+3)+'" y2="'+(row2y+H/2)+'" stroke="#4A7FFF" stroke-width="2.2" marker-end="url(#aB)"/>';
  svg += '<line x1="'+xs[2]+'" y1="'+(row2y+H/2)+'" x2="'+(xs[1]+W+3)+'" y2="'+(row2y+H/2)+'" stroke="#4A7FFF" stroke-width="2.2" marker-end="url(#aB)"/>';

  // loop dashed: box5 -> box4 (reapresentar)
  const loopX = xs[3]+30;
  svg += '<path d="M'+loopX+','+row2y+' L'+loopX+','+(row1y+H+12)+' L'+(xs[3]+W/2-5)+','+(row1y+H+12)+' L'+(xs[3]+W/2-5)+','+(row1y+H+2)+'" fill="none" stroke="#F59E0B" stroke-width="2" stroke-dasharray="5,5" marker-end="url(#aO)"/>';
  svg += '<rect x="'+(loopX-100)+'" y="'+(row1y+H+2)+'" width="104" height="20" rx="10" fill="#FFF3E0"/>';
  svg += '<text x="'+(loopX-48)+'" y="'+(row1y+H+16)+'" text-anchor="middle" font-family="Arial" font-weight="700" font-size="9.5" fill="#B45309">REFAZER (até 2x)</text>';

  svg += '</svg>';
  return svg;
}

