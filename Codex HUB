function copyText(text, btn){
  function doCopy(){
    btn.classList.add('copied');
    btn.innerHTML = '&#10003; Copiado';
    showToast();
    setTimeout(function(){ btn.classList.remove('copied'); btn.innerHTML = '&#10209; Copiar'; }, 1800);
  }
  if(navigator.clipboard && navigator.clipboard.writeText){
    navigator.clipboard.writeText(text).then(doCopy).catch(function(){fallbackCopy(text,doCopy);});
  } else {
    fallbackCopy(text,doCopy);
  }
}
function fallbackCopy(text,cb){
  const ta=document.createElement('textarea');
  ta.value=text; ta.style.position='fixed'; ta.style.left='-9999px';
  document.body.appendChild(ta); ta.select();
  try{ document.execCommand('copy'); cb(); }catch(e){}
  document.body.removeChild(ta);
}
function showToast(){
  const t=document.getElementById('toast');
  t.classList.add('show');
  setTimeout(function(){t.classList.remove('show');},1900);
}

function escapeForTemplate(str){
  return str.replace(/\\/g,'\\\\').replace(/`/g,'\\`').replace(/\$/g,'\\$');
}

